# ── Кэш статики (шрифты/webp nginx по умолчанию не кэшировал) ──
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTP_HOST} ^www\.metallomsk\.ru$ [NC]
  RewriteRule ^ https://metallomsk.ru%{REQUEST_URI} [R=301,L,NE]
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(woff2|woff|ttf|webp|css|js|png|jpg|jpeg|svg|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # ── Заголовки безопасности ──
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# ── gzip (на случай, если статику отдаёт Apache) ──
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript image/svg+xml application/json
</IfModule>
