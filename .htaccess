# ── Кэш статики (шрифты/webp nginx по умолчанию не кэшировал) ──
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTP_HOST} ^www\.metallomsk\.ru$ [NC]
  RewriteRule ^ https://metallomsk.ru%{REQUEST_URI} [R=301,L,NE]

  # Убираем index.html из корня и вложенных разделов.
  RewriteCond %{THE_REQUEST} \s/+(.*/)?index\.html(?:[?\s]) [NC]
  RewriteRule ^(.*/)?index\.html$ /$1 [R=301,L,NE]

  # Постоянные редиректы со старых файлов на человеко-понятные URL.
  RewriteCond %{THE_REQUEST} \s/+catalog\.html(?:[?\s]) [NC]
  RewriteRule ^catalog\.html$ /catalog/ [R=301,L,NE]
  RewriteCond %{THE_REQUEST} \s/+profnastil\.html(?:[?\s]) [NC]
  RewriteRule ^profnastil\.html$ /catalog/profnastil/ [R=301,L,NE]
  RewriteCond %{THE_REQUEST} \s/+metallocherepitsa\.html(?:[?\s]) [NC]
  RewriteRule ^metallocherepitsa\.html$ /catalog/metallocherepitsa/ [R=301,L,NE]
  RewriteCond %{THE_REQUEST} \s/+siding\.html(?:[?\s]) [NC]
  RewriteRule ^siding\.html$ /catalog/siding/ [R=301,L,NE]
  RewriteCond %{THE_REQUEST} \s/+evroshtaketnik\.html(?:[?\s]) [NC]
  RewriteRule ^evroshtaketnik\.html$ /catalog/evroshtaketnik/ [R=301,L,NE]
  RewriteCond %{THE_REQUEST} \s/+ploskiy-list\.html(?:[?\s]) [NC]
  RewriteRule ^ploskiy-list\.html$ /catalog/ploskiy-list/ [R=301,L,NE]
  RewriteCond %{THE_REQUEST} \s/+chernyy-metall\.html(?:[?\s]) [NC]
  RewriteRule ^chernyy-metall\.html$ /catalog/chernyy-metall/ [R=301,L,NE]
  RewriteCond %{THE_REQUEST} \s/+evrozhalyuzi\.html(?:[?\s]) [NC]
  RewriteRule ^evrozhalyuzi\.html$ /catalog/evrozhalyuzi/ [R=301,L,NE]
  RewriteCond %{THE_REQUEST} \s/+dobornye-elementy\.html(?:[?\s]) [NC]
  RewriteRule ^dobornye-elementy\.html$ /catalog/dobornye-elementy/ [R=301,L,NE]
  RewriteCond %{THE_REQUEST} \s/+soffity-docke\.html(?:[?\s]) [NC]
  RewriteRule ^soffity-docke\.html$ /catalog/soffity-docke/ [R=301,L,NE]
  RewriteCond %{THE_REQUEST} \s/+vodostochnye-sistemy-docke\.html(?:[?\s]) [NC]
  RewriteRule ^vodostochnye-sistemy-docke\.html$ /catalog/vodostochnye-sistemy-docke/ [R=301,L,NE]
  RewriteCond %{THE_REQUEST} \s/+gryadki-klumby\.html(?:[?\s]) [NC]
  RewriteRule ^gryadki-klumby\.html$ /catalog/gryadki-klumby/ [R=301,L,NE]
  RewriteCond %{THE_REQUEST} \s/+calculator\.html(?:[?\s]) [NC]
  RewriteRule ^calculator\.html$ /calculator/ [R=301,L,NE]
  RewriteCond %{THE_REQUEST} \s/+buyers\.html(?:[?\s]) [NC]
  RewriteRule ^buyers\.html$ /buyers/ [R=301,L,NE]
  RewriteCond %{THE_REQUEST} \s/+delivery\.html(?:[?\s]) [NC]
  RewriteRule ^delivery\.html$ /delivery/ [R=301,L,NE]
  RewriteCond %{THE_REQUEST} \s/+blog\.html(?:[?\s]) [NC]
  RewriteRule ^blog\.html$ /blog/ [R=301,L,NE]
  RewriteCond %{THE_REQUEST} \s/+article-roofing\.html(?:[?\s]) [NC]
  RewriteRule ^article-roofing\.html$ /blog/kak-vybrat-krovelnyy-material/ [R=301,L,NE]
  RewriteCond %{THE_REQUEST} \s/+contacts\.html(?:[?\s]) [NC]
  RewriteRule ^contacts\.html$ /contacts/ [R=301,L,NE]
  RewriteCond %{THE_REQUEST} \s/+offer\.html(?:[?\s]) [NC]
  RewriteRule ^offer\.html$ /legal/offer/ [R=301,L,NE]
  RewriteCond %{THE_REQUEST} \s/+return-policy\.html(?:[?\s]) [NC]
  RewriteRule ^return-policy\.html$ /legal/return/ [R=301,L,NE]
  RewriteCond %{THE_REQUEST} \s/+policy-personal-data\.html(?:[?\s]) [NC]
  RewriteRule ^policy-personal-data\.html$ /legal/personal-data/ [R=301,L,NE]
  RewriteCond %{THE_REQUEST} \s/+policy-privacy\.html(?:[?\s]) [NC]
  RewriteRule ^policy-privacy\.html$ /legal/privacy/ [R=301,L,NE]
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(woff2|woff|ttf|webp|css|js|png|jpg|jpeg|svg|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # ── Заголовки безопасности ──
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# ── gzip (на случай, если статику отдаёт Apache) ──
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript image/svg+xml application/json
</IfModule>
